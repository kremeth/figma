+++ b/fragments/nc-hero-scorecard.html
@@ -0,0 +1,33 @@
+        <div class="nc-hero__scorecard" role="region" aria-label="Health score improves from 77 to 87. In the next 30 days: better recovery, more energy, deeper sleep.">
+          <!-- Left: dual-segment ring (current 77%, projected +10 to 87%) -->
+          <div class="nc-hero__sc-left" aria-hidden="true">
+            <div class="nc-hero__sc-ring">
+              <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
+                <circle class="nc-hero__sc-ring-track" cx="50" cy="50" r="44" pathLength="100"></circle>
+                <!-- 0→77% -->
+                <circle class="nc-hero__sc-ring-arc--base" cx="50" cy="50" r="44" pathLength="100" transform="rotate(-90 50 50)"></circle>
+                <!-- 77%→87% (projected gain) -->
+                <circle class="nc-hero__sc-ring-arc--delta" cx="50" cy="50" r="44" pathLength="100" transform="rotate(-90 50 50)"></circle>
+              </svg>
+              <div class="nc-hero__sc-ring-inner">
+                <div class="nc-hero__sc-move">
+                  <span class="nc-hero__sc-from">77</span>
+                  <span class="nc-hero__sc-arrow" aria-hidden="true">→</span>
+                  <span class="nc-hero__sc-to">87</span>
+                </div>
+                <span class="nc-hero__sc-delta">+10 pts</span>
+              </div>
+            </div>
+          </div>
+
+          <div class="nc-hero__sc-sep" aria-hidden="true"></div>
+
+          <div class="nc-hero__sc-right">
+            <p class="nc-hero__sc-eyebrow">Expected in 30 days</p>
+            <ul class="nc-hero__sc-benefits">
+              <li class="nc-hero__sc-chip"><span class="nc-hero__sc-chip-mark" aria-hidden="true"></span>Better Recovery</li>
+              <li class="nc-hero__sc-chip"><span class="nc-hero__sc-chip-mark" aria-hidden="true"></span>More Energy</li>
+              <li class="nc-hero__sc-chip"><span class="nc-hero__sc-chip-mark" aria-hidden="true"></span>Deeper Sleep</li>
+            </ul>
+          </div>
+        </div>
